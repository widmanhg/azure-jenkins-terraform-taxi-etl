pipeline {
    agent any

    environment {
        TF_SUFFIX       = "etl01"
        PARQUET_FILE    = "data/yellow_tripdata_2024-01.parquet"
        BLOB_CONTAINER  = "raw"
        DATABRICKS_JOB  = "nyc-taxi-etl"
        RESOURCE_GROUP  = "taxi-etl-rg"
        STORAGE_ACCOUNT = "taxietletl01"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Setup Python') {
            steps {
                sh '''
                    python3 -m venv venv
                    venv/bin/pip install --quiet \
                        azure-storage-blob \
                        databricks-sdk \
                        pyodbc \
                        pandas \
                        pyarrow \
                        requests \
                        pytest \
                        pytest-cov
                '''
            }
        }

        stage('Unit Tests') {
            steps {
                sh '''
                    venv/bin/python3 -m pytest tests/unit/ \
                        --cov=functions \
                        --cov-report=term-missing -q
                '''
            }
        }

        stage('Terraform Init') {
            steps {
                withCredentials([
                    azureServicePrincipal('AZURE_SERVICE_PRINCIPAL'),
                    string(credentialsId: 'sql_admin_password', variable: 'SQL_ADMIN_PASSWORD')
                ]) {
                    dir('terraform') {
                        sh '''
                        terraform init -reconfigure
                        '''
                    }
                }
            }
        }

        stage('Terraform Apply') {
            steps {
                withCredentials([
                    azureServicePrincipal('AZURE_SERVICE_PRINCIPAL'),
                    string(credentialsId: 'sql_admin_password', variable: 'SQL_ADMIN_PASSWORD')
                ]) {
                    dir('terraform') {
                        sh '''
                        terraform apply -auto-approve \
                          -var="client_id=$AZURE_CLIENT_ID" \
                          -var="client_secret=$AZURE_CLIENT_SECRET" \
                          -var="subscription_id=$AZURE_SUBSCRIPTION_ID" \
                          -var="tenant_id=$AZURE_TENANT_ID" \
                          -var="suffix=$TF_SUFFIX" \
                          -var="sql_admin_password=$SQL_ADMIN_PASSWORD"
                        '''
                    }
                }
            }
        }

        stage('Get Terraform Outputs') {
            steps {
                dir('terraform') {
                    script {

                        env.TF_SQL_SERVER = sh(
                            script: "terraform output -raw sql_server_fqdn",
                            returnStdout: true
                        ).trim()

                        env.TF_SQL_DB = sh(
                            script: "terraform output -raw sql_database_name",
                            returnStdout: true
                        ).trim()

                        env.TF_DATABRICKS_URL = sh(
                            script: "terraform output -raw databricks_workspace_url",
                            returnStdout: true
                        ).trim()

                        env.DATABRICKS_HOST = "https://${env.TF_DATABRICKS_URL}"
                    }
                }
            }
        }

        stage('Get Storage Connection String') {
            steps {
                withCredentials([
                    azureServicePrincipal('AZURE_SERVICE_PRINCIPAL')
                ]) {
                    script {

                        env.AZURE_STORAGE_CONNECTION_STRING = sh(
                            script: """
                            az storage account show-connection-string \
                              --name ${STORAGE_ACCOUNT} \
                              --resource-group ${RESOURCE_GROUP} \
                              --query connectionString \
                              -o tsv
                            """,
                            returnStdout: true
                        ).trim()

                    }
                }
            }
        }

        stage('Upload to Blob') {
            steps {
                script {

                    def output = sh(
                        script: """
                        AZURE_STORAGE_CONNECTION_STRING="${env.AZURE_STORAGE_CONNECTION_STRING}" \
                        venv/bin/python3 functions/upload.py \
                          --file ${PARQUET_FILE} \
                          --container ${BLOB_CONTAINER}
                        """,
                        returnStdout: true
                    ).trim()

                    echo output

                    def blobLine = output.split('\n').find {
                        it.startsWith("BLOB_NAME=")
                    }

                    env.BLOB_NAME = blobLine.replace("BLOB_NAME=", "")
                }
            }
        }

        stage('Run Databricks') {
            steps {
                withCredentials([
                    string(credentialsId: 'databricks-token', variable: 'DATABRICKS_TOKEN')
                ]) {
                    script {

                        def output = sh(
                            script: """
                            DATABRICKS_HOST="${env.DATABRICKS_HOST}" \
                            DATABRICKS_TOKEN="$DATABRICKS_TOKEN" \
                            venv/bin/python3 functions/run_databricks.py \
                              --blob-name ${env.BLOB_NAME} \
                              --blob-container ${BLOB_CONTAINER} \
                              --job-name ${DATABRICKS_JOB}
                            """,
                            returnStdout: true
                        ).trim()

                        echo output

                        def runLine = output.split('\n').find {
                            it.startsWith("DATABRICKS_RUN_ID=")
                        }

                        if (runLine) {
                            env.DATABRICKS_RUN_ID =
                                runLine.replace("DATABRICKS_RUN_ID=", "")
                        }
                    }
                }
            }
        }

        stage('Validate Data') {
            steps {

                withCredentials([
                    string(credentialsId: 'sql_admin_password',
                           variable: 'AZURE_SQL_PASSWORD')
                ]) {

                    script {

                        env.AZURE_SQL_SERVER = env.TF_SQL_SERVER
                        env.AZURE_SQL_DATABASE = env.TF_SQL_DB
                        env.AZURE_SQL_USERNAME = "sqladmin"

                        def parts = env.BLOB_NAME.tokenize('/')

                        env.RUN_DATE =
                            "${parts[1]}-${parts[2]}-${parts[3]}"
                    }

                    sh """
                    AZURE_SQL_SERVER=${env.AZURE_SQL_SERVER} \
                    AZURE_SQL_DATABASE=${env.AZURE_SQL_DATABASE} \
                    AZURE_SQL_USERNAME=${env.AZURE_SQL_USERNAME} \
                    AZURE_SQL_PASSWORD=$AZURE_SQL_PASSWORD \
                    venv/bin/python3 functions/validate.py \
                      --run-date ${env.RUN_DATE}
                    """

                }
            }
        }

        stage('Integration Tests') {
            steps {

                withCredentials([
                    string(credentialsId: 'databricks-token',
                           variable: 'DATABRICKS_TOKEN'),
                    string(credentialsId: 'sql_admin_password',
                           variable: 'AZURE_SQL_PASSWORD')
                ]) {

                    sh """
                    DATABRICKS_HOST=${env.DATABRICKS_HOST} \
                    AZURE_SQL_SERVER=${env.TF_SQL_SERVER} \
                    AZURE_SQL_DATABASE=${env.TF_SQL_DB} \
                    AZURE_SQL_USERNAME=sqladmin \
                    AZURE_SQL_PASSWORD=$AZURE_SQL_PASSWORD \
                    RUN_DATE=${env.RUN_DATE} \
                    venv/bin/python3 -m pytest \
                        tests/integration \
                        tests/data_quality -q
                    """

                }
            }
        }
    }

    post {

        success {
            echo "PIPELINE OK"
        }

        failure {
            echo "PIPELINE FAILED"
        }

        always {
            deleteDir()
        }
    }
}