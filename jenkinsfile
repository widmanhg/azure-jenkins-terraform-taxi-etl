pipeline {
    agent any

    environment {
        TF_SUFFIX = "etl01"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Terraform Init') {
            steps {
                withCredentials([azureServicePrincipal('AZURE_SERVICE_PRINCIPAL')]) {
                    dir('terraform') {
                        sh '''
                            terraform init -reconfigure \
                              -var="client_id=${AZURE_CLIENT_ID}" \
                              -var="client_secret=${AZURE_CLIENT_SECRET}" \
                              -var="subscription_id=${AZURE_SUBSCRIPTION_ID}" \
                              -var="tenant_id=${AZURE_TENANT_ID}" \
                              -var="suffix=${TF_SUFFIX}" \
                              -var="synapse_sql_password=placeholder"
                        '''
                    }
                }
            }
        }

        stage('Terraform Plan') {
            steps {
                withCredentials([
                    azureServicePrincipal('AZURE_SERVICE_PRINCIPAL'),
                    string(credentialsId: 'SYNAPSE_SQL_PASSWORD', variable: 'SYNAPSE_PASS')
                ]) {
                    dir('terraform') {
                        sh '''
                            terraform plan \
                              -var="client_id=${AZURE_CLIENT_ID}" \
                              -var="client_secret=${AZURE_CLIENT_SECRET}" \
                              -var="subscription_id=${AZURE_SUBSCRIPTION_ID}" \
                              -var="tenant_id=${AZURE_TENANT_ID}" \
                              -var="suffix=${TF_SUFFIX}" \
                              -var="synapse_sql_password=${SYNAPSE_PASS}" \
                              -out=tfplan
                        '''
                    }
                }
            }
        }

        stage('Terraform Apply') {
            steps {
                withCredentials([azureServicePrincipal('AZURE_SERVICE_PRINCIPAL')]) {
                    dir('terraform') {
                        sh 'terraform apply -auto-approve tfplan'
                    }
                }
            }
        }

        stage('Upload Raw Data') {
            steps {
                withCredentials([azureServicePrincipal('AZURE_SERVICE_PRINCIPAL')]) {
                    sh '''
                        az login --service-principal \
                          -u ${AZURE_CLIENT_ID} \
                          -p ${AZURE_CLIENT_SECRET} \
                          --tenant ${AZURE_TENANT_ID}

                        az storage blob upload \
                          --account-name taxietl${TF_SUFFIX} \
                          --container-name raw \
                          --name yellow_tripdata_2024-01.parquet \
                          --file data/yellow_tripdata_2024-01.parquet \
                          --auth-mode login \
                          --overwrite
                    '''
                }
            }
        }

        stage('Trigger ADF Pipeline') {
            steps {
                withCredentials([azureServicePrincipal('AZURE_SERVICE_PRINCIPAL')]) {
                    sh '''
                        az datafactory pipeline create-run \
                          --resource-group taxi-etl-rg \
                          --factory-name taxi-etl-adf-${TF_SUFFIX} \
                          --name TaxiETLPipeline
                    '''
                }
            }
        }
    }

    post {
        failure {
            echo "Pipeline fallido — revisa los logs arriba"
        }
        success {
            echo "Pipeline completado exitosamente"
        }
    }
}